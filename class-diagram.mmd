        +Date createdAt
        +Date updatedAt
    }

    class TaskType {
        +string _id
        +string name
        +string colorCode
        +Date createdAt
        +Date updatedAt
    }

    class Technology {
        +string _id
        +string name
        +string type
        +Date createdAt
        +Date updatedAt
    }

    class ProjectTechnology {
        +string _id
        +string projectId
        +string technologyId
        +Date createdAt
        +Date updatedAt
    }

    class JobPosition {
        +string _id
        +string name
        +Date createdAt
        +Date updatedAt
    }

    class Payroll {
        +string _id
        +string userId
        +number month
        +number year
        +number totalHours
        +number totalAmount
        +string paymentStatus
        +Date processedDate
        +Date createdAt
        +Date updatedAt
    }

    class Contract {
        +string _id
        +string userId
        +string contractType
        +number salaryAmount
        +Date startDate
        +Date endDate
        +Date createdAt
        +Date updatedAt
    }

