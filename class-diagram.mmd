        +string customerPhone
        +boolean isActive
        +boolean isArchived
        +Date startDate
        +Date endDate
        +Date createdAt
        +Date updatedAt
    }

    class ProjectMember {
        +string _id
        +string projectId
        +string userId
        +string memberRole
