        +string phoneNumber
        +string address
        +Date dateOfBirth
        +string gender
        +number salary
        +string jobPositionId
        +boolean isActive
        +Date createdAt
        +Date updatedAt
    }

    class Timesheet {
        +string _id
        +string taskName
        +string description
